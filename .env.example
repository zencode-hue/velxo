# ─── Database (Supabase) ──────────────────────────────────────────────────────
# Get this from: Supabase Dashboard → Settings → Database → Connection string (URI)
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-min-32-chars"

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─── Encryption ───────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY="your-64-char-hex-encryption-key"

# ─── NOWPayments (Crypto) ─────────────────────────────────────────────────────
NOWPAYMENTS_API_KEY="your-nowpayments-api-key"
NOWPAYMENTS_IPN_SECRET="your-nowpayments-ipn-secret"

# ─── Discord ──────────────────────────────────────────────────────────────────
# Webhook URL for sale notifications
DISCORD_WEBHOOK_URL="https://discord.com/api/webhooks/..."
# Webhook URL for daily deals announcement (falls back to DISCORD_WEBHOOK_URL)
DISCORD_DEALS_WEBHOOK_URL="https://discord.com/api/webhooks/..."
# Webhook URL specifically for Binance gift card code submissions
DISCORD_GIFT_CARD_WEBHOOK_URL="https://discord.com/api/webhooks/..."
# Your Discord server invite link (for manual payments)
DISCORD_SERVER_URL="https://discord.gg/your-server"

# ─── Cron ─────────────────────────────────────────────────────────────────────
# Secret token to protect cron endpoints — generate with: openssl rand -hex 16
CRON_SECRET="your-cron-secret"

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY="re_..."
EMAIL_FROM="noreply@yourdomain.com"
ADMIN_EMAIL="admin@yourdomain.com"

# ─── Email (Nodemailer fallback) ──────────────────────────────────────────────
SMTP_HOST="smtp.yourdomain.com"
SMTP_PORT="587"
SMTP_USER="your-smtp-user"
SMTP_PASS="your-smtp-password"

# ─── Admin ────────────────────────────────────────────────────────────────────
# Password for the hidden admin login button on the login page
ADMIN_PASSWORD="Fadekemi123@"

# ─── Affiliate ────────────────────────────────────────────────────────────────
AFFILIATE_COMMISSION_PCT="10"

# ─── Live Chat (Crisp) ────────────────────────────────────────────────────────
# Get your Website ID from crisp.chat dashboard
NEXT_PUBLIC_CRISP_WEBSITE_ID=""

# ─── Flutterwave (Card Payments) ─────────────────────────────────────────────
FLUTTERWAVE_SECRET_KEY="FLWSECK_TEST-..."
FLUTTERWAVE_PUBLIC_KEY="FLWPUBK_TEST-..."
# Webhook hash secret — set in Flutterwave dashboard → Webhooks
FLUTTERWAVE_WEBHOOK_SECRET="your-flutterwave-webhook-secret"

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="MetraMart"
