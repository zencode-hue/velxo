// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  CUSTOMER
  ADMIN
}

enum Category {
  STREAMING
  AI_TOOLS
  SOFTWARE
  GAMING
}

enum InventoryStatus {
  AVAILABLE
  DELIVERED
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  PENDING_STOCK
  REFUNDED
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String?
  name          String?
  role          Role      @default(CUSTOMER)
  emailVerified DateTime?
  balance       Decimal   @default(0) @db.Decimal(10, 2)
  isBanned      Boolean   @default(false)
  banReason     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  orders             Order[]
  reviews            Review[]
  affiliate          Affiliate?
  partnerAffiliate   PartnerAffiliate?
  sessions           Session[]
  loginAttempts      LoginAttempt[]
  balanceTransactions BalanceTransaction[]

  @@index([email])
}

model Product {
  id          String   @id @default(cuid())
  slug        String?
  title       String
  description String
  price       Decimal  @db.Decimal(10, 2)
  category    Category
  imageUrl    String?
  isActive        Boolean  @default(true)
  isFeatured      Boolean  @default(false)
  unlimitedStock  Boolean  @default(false)
  avgRating       Decimal  @default(0) @db.Decimal(3, 2)
  stockCount      Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  inventory InventoryItem[]
  orders    Order[]
  reviews   Review[]

  @@index([category])
  @@index([title])
  @@index([isActive])
  @@index([isFeatured])
}

model InventoryItem {
  id            String          @id @default(cuid())
  productId     String
  encryptedData String          // AES-256-GCM encrypted credentials
  iv            String          // Initialization vector
  authTag       String          // GCM auth tag
  status        InventoryStatus @default(AVAILABLE)
  createdAt     DateTime        @default(now())

  product     Product      @relation(fields: [productId], references: [id])
  deliveryLog DeliveryLog?

  @@index([productId, status])
}

model Order {
  id              String      @id @default(cuid())
  userId          String?
  guestEmail      String?
  productId       String
  amount          Decimal     @db.Decimal(10, 2)
  discountAmount  Decimal     @default(0) @db.Decimal(10, 2)
  status          OrderStatus @default(PENDING)
  paymentProvider String
  paymentRef      String?
  discountCodeId  String?
  adminNote       String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user         User?         @relation(fields: [userId], references: [id])
  product      Product       @relation(fields: [productId], references: [id])
  deliveryLog  DeliveryLog?
  discountCode DiscountCode? @relation(fields: [discountCodeId], references: [id])

  @@index([userId])
  @@index([guestEmail])
  @@index([productId])
  @@index([status])
}

model DeliveryLog {
  id              String   @id @default(cuid())
  orderId         String   @unique
  userId          String?
  productId       String
  inventoryItemId String   @unique
  deliveredAt     DateTime @default(now())

  order         Order         @relation(fields: [orderId], references: [id])
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])

  @@index([userId])
}

model DiscountCode {
  id         String       @id @default(cuid())
  code       String       @unique
  type       DiscountType
  value      Decimal      @db.Decimal(10, 2)
  usageLimit Int
  usageCount Int          @default(0)
  expiresAt  DateTime
  createdAt  DateTime     @default(now())

  orders     Order[]
  userUsages DiscountUsage[]

  @@index([code])
}

model DiscountUsage {
  id             String   @id @default(cuid())
  discountCodeId String
  userId         String
  createdAt      DateTime @default(now())

  discountCode DiscountCode @relation(fields: [discountCodeId], references: [id])

  @@unique([discountCodeId, userId])
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  productId String
  rating    Int      // 1-5
  comment   String?  @db.VarChar(1000)
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([userId, productId])
  @@index([productId])
}

model Affiliate {
  id            String  @id @default(cuid())
  userId        String  @unique
  referralCode  String  @unique
  commissionPct Decimal @db.Decimal(5, 2)
  totalEarned   Decimal @default(0) @db.Decimal(10, 2)
  pendingPayout Decimal @default(0) @db.Decimal(10, 2)
  createdAt     DateTime @default(now())

  user      User       @relation(fields: [userId], references: [id])
  referrals Referral[]

  @@index([referralCode])
}

model Referral {
  id             String   @id @default(cuid())
  affiliateId    String
  referredUserId String   @unique
  createdAt      DateTime @default(now())

  affiliate Affiliate @relation(fields: [affiliateId], references: [id])
}

model WebhookLog {
  id        String   @id @default(cuid())
  provider  String   // "stripe" | "nowpayments" | "cryptomus"
  eventType String
  payload   Json
  status    String   // "processed" | "failed"
  createdAt DateTime @default(now())

  @@index([provider, createdAt])
}

model AdminAuditLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String
  entityType String
  entityId   String
  createdAt  DateTime @default(now())

  @@index([adminId, createdAt])
}

model LoginAttempt {
  id        String   @id @default(cuid())
  userId    String
  success   Boolean
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Balance / Wallet ─────────────────────────────────────────────────────────

enum BalanceTxType {
  TOPUP
  PURCHASE
  REFUND
  ADMIN_CREDIT
  ADMIN_DEBIT
  AFFILIATE_PAYOUT
}

model BalanceTransaction {
  id          String         @id @default(cuid())
  userId      String
  type        BalanceTxType
  amount      Decimal        @db.Decimal(10, 2)
  description String?
  orderId     String?
  createdAt   DateTime       @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
}

// ─── Blog ─────────────────────────────────────────────────────────────────────

model BlogPost {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  excerpt     String
  content     String   @db.Text
  category    String   @default("General")
  emoji       String   @default("📝")
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@index([published, createdAt])
}

// ─── Page Analytics ───────────────────────────────────────────────────────────

model PageView {
  id        String   @id @default(cuid())
  path      String
  country   String?
  city      String?
  referrer  String?
  userAgent String?
  sessionId String?
  userId    String?
  ip        String?
  device    String?  // "mobile" | "tablet" | "desktop"
  browser   String?
  os        String?
  createdAt DateTime @default(now())

  @@index([path, createdAt])
  @@index([createdAt])
  @@index([country])
  @@index([sessionId])
  @@index([userId])
}

// ─── Site Settings ────────────────────────────────────────────────────────────

model SiteSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ─── Staff ────────────────────────────────────────────────────────────────────

enum StaffStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

model StaffMember {
  id           String      @id @default(cuid())
  email        String      @unique
  passwordHash String
  name         String
  position     String?     // e.g. "Support Agent", "Inventory Manager"
  bio          String?
  phone        String?
  avatarUrl    String?
  status       StaffStatus @default(PENDING)
  joinedAt     DateTime?
  lastActiveAt DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([email])
  @@index([status])
}

// ─── Partner Affiliate (paid, can withdraw) ───────────────────────────────────

enum PartnerAffiliateStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum PayoutStatus {
  PENDING
  APPROVED
  REJECTED
}

model PartnerAffiliate {
  id            String                 @id @default(cuid())
  userId        String                 @unique
  referralCode  String                 @unique
  commissionPct Decimal                @default(15) @db.Decimal(5, 2)
  balance       Decimal                @default(0) @db.Decimal(10, 2)
  totalEarned   Decimal                @default(0) @db.Decimal(10, 2)
  totalPaidOut  Decimal                @default(0) @db.Decimal(10, 2)
  cryptoWallet  String?
  walletType    String?                // "BTC" | "ETH" | "USDT_TRC20" | "USDT_ERC20" | "BNB"
  status        PartnerAffiliateStatus @default(PENDING)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  user           User                   @relation(fields: [userId], references: [id])
  referrals      PartnerReferral[]
  payoutRequests PartnerPayoutRequest[]

  @@index([referralCode])
  @@index([status])
}

model PartnerReferral {
  id                String   @id @default(cuid())
  partnerAffiliateId String
  referredUserId    String   @unique
  commissionEarned  Decimal  @default(0) @db.Decimal(10, 2)
  createdAt         DateTime @default(now())

  partnerAffiliate PartnerAffiliate @relation(fields: [partnerAffiliateId], references: [id])
}

model PartnerPayoutRequest {
  id                 String       @id @default(cuid())
  partnerAffiliateId String
  amount             Decimal      @db.Decimal(10, 2)
  cryptoWallet       String
  walletType         String
  status             PayoutStatus @default(PENDING)
  adminNote          String?
  txHash             String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  partnerAffiliate PartnerAffiliate @relation(fields: [partnerAffiliateId], references: [id])

  @@index([partnerAffiliateId])
  @@index([status])
}
